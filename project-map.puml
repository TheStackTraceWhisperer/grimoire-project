    rectangle "PositionDTOTest" <<class>>
    rectangle "RenderableDTOTest" <<class>>
    rectangle "StatsDTOTest" <<class>>
  }

  package "com.grimoire.contracts.wire.dto (test)" {
    rectangle "CharacterListResponseTest" <<class>>
