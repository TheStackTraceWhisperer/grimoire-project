@startuml
' ── Toggle test-scoped classes ──
!$SHOW_TESTS = %false()
left to right direction
title Grimoire — Full Project Map (Modules & Classes)
footer Generated 2026-03-29

skinparam {
  shadowing false
  defaultFontSize 11
  rectangleFontSize 10
}

skinparam package {
  BackgroundColor<<pom>> #F5F5F5
  BackgroundColor<<contracts>> #E8F5E9
  BackgroundColor<<domain>> #E3F2FD
  BackgroundColor<<application>> #FFF3E0
  BackgroundColor<<infra>> #FCE4EC
  BackgroundColor<<app>> #F3E5F5
  BackgroundColor<<testkit>> #FFFDE7
}

skinparam rectangle {
  BackgroundColor<<pom>> #F5F5F5
  BackgroundColor<<record>> #C8E6C9
  BackgroundColor<<interface>> #B3E5FC
  BackgroundColor<<enum>> #FFE0B2
  BackgroundColor<<class>> #E1BEE7
}

!if ($SHOW_TESTS)
legend right
  |= Stereotype |= Color |
  | <<record>> | <back:#C8E6C9>   record   </back> |
  | <<interface>> | <back:#B3E5FC>   interface   </back> |
  | <<enum>> | <back:#FFE0B2>   enum   </back> |
  | <<class>> | <back:#E1BEE7>   class (test)   </back> |
end legend
!else
legend right
  |= Stereotype |= Color |
  | <<record>> | <back:#C8E6C9>   record   </back> |
  | <<interface>> | <back:#B3E5FC>   interface   </back> |
  | <<enum>> | <back:#FFE0B2>   enum   </back> |
end legend
!endif

' ── POMs ──
rectangle "external-bom" <<pom>>
rectangle "internal-bom" <<pom>>
rectangle "grimoire-parent" <<pom>>
rectangle "grimoire-starter-parent" <<pom>>

' ── contracts-api ──
package "grimoire-contracts-api" <<contracts>> {
  package "com.grimoire.contracts.api.component" {
    rectangle "ComponentDTO" <<interface>>
  }
}

