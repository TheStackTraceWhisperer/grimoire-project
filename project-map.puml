    rectangle "CharacterSelectionSuccessTest" <<class>>
    rectangle "ChatBroadcastTest" <<class>>
    rectangle "ChatMessageTest" <<class>>
    rectangle "CreateGroupTest" <<class>>
    rectangle "CreateGroupResponseTest" <<class>>
    rectangle "EntityDespawnTest" <<class>>
    rectangle "EntitySpawnTest" <<class>>
    rectangle "GameStateUpdateTest" <<class>>
    rectangle "GroupMessageTest" <<class>>
    rectangle "GroupMessageBroadcastTest" <<class>>
