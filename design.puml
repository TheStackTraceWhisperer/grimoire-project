@startuml
title Grimoire Module Dependency Topology\n(with system placement — ADR-003)

skinparam package {
  BackgroundColor<<contracts>> #E8F5E9
  BackgroundColor<<domain>> #E3F2FD
  BackgroundColor<<application>> #FFF3E0
  BackgroundColor<<infra>> #FCE4EC
  BackgroundColor<<app>> #F3E5F5
  BackgroundColor<<testkit>> #FFFDE7
}

' ── Contracts Layer ──
package "contracts" <<contracts>> {
  [grimoire-contracts-api] as API
  [grimoire-contracts-wire] as WIRE
}

' ── Domain Layer ──
package "domain" <<domain>> {
  [grimoire-domain-core] as DCORE
  [grimoire-domain-combat] as DCOMBAT
  [grimoire-domain-navigation] as DNAV
}

' ── Application Layer ──
package "application" <<application>> {
  [grimoire-application-core] as ACORE
  [grimoire-application-session] as ASESSION

  note right of ACORE
    **Pure systems (Wave 3.5)**
    MovementSystem
    CombatSystem
    LevelUpSystem
    NpcAiSystem
    PortalCooldownSystem
    SpatialGridSystem
    ZoneChangeSystem
    GroupService
    ──
    **Ports**
    GameSystem (interface)
    GameEventPort (interface)
    GameConfig (interface)
  end note
}

' ── Infrastructure Layer ──
package "infrastructure" <<infra>> {
  [grimoire-infra-network-netty] as NETTY
  [grimoire-infra-security-keycloak] as KEYCLOAK
  [grimoire-infra-persistence-jpa] as JPA
  [grimoire-infra-observability] as OBS

  note right of NETTY
    **Adapter systems**
    NetworkSyncSystem
    NetworkVisibilitySystem
    PlayerInputSystem
    ──
    **Channel map**
    sessionId → Channel
    (no Channel in domain)
  end note

  note right of JPA
    **Adapter system**
    PersistenceSystem
  end note
}

' ── Application Assembly ──
package "applications" <<app>> {
  [grimoire-server-app] as SERVER
  [grimoire-web-app] as WEB
  [grimoire-client-app] as CLIENT

  note right of SERVER
    **Thread driver**
    while(isRunning) loop
    delta-time capping
    SystemScheduler.tick()
    ──
    **Content bootstrap**
    PrefabRegistry
    NpcFactory
    ZoneInitializer
    ──
    **Config binding**
    @ConfigurationProperties
    → GameConfig
  end note
}

' ── Test Kit ──
package "test support" <<testkit>> {
  [grimoire-test-kit] as TESTKIT
}

' ── Dependency Rules ──

' contracts: no internal deps
' wire may use api for shared types
WIRE ..> API : "shared types"

' domain depends only on contracts-api
DCORE --> API
DCOMBAT --> API
DCOMBAT --> DCORE
DNAV --> API
DNAV --> DCORE

' application depends on domain + contracts-api
ACORE --> API
ACORE --> DCORE
ACORE --> DCOMBAT
ACORE --> DNAV
ASESSION --> API
ASESSION --> DCORE

' infra depends on application ports + contracts
NETTY --> ACORE
NETTY --> WIRE
KEYCLOAK --> ACORE
JPA --> ACORE
OBS --> API

' apps compose everything (assembly only)
SERVER --> ACORE
SERVER --> ASESSION
SERVER --> NETTY
SERVER --> KEYCLOAK
SERVER --> JPA
SERVER --> OBS

WEB --> ACORE
WEB --> ASESSION
WEB --> KEYCLOAK
WEB --> JPA
WEB --> OBS

CLIENT --> ACORE
CLIENT --> WIRE
CLIENT --> NETTY

' test-kit depends on contracts + domain only
TESTKIT --> API
TESTKIT --> DCORE

' ── Layer boundary notes ──
note bottom of "contracts"
  No framework annotations.
  Pure Java records + interfaces.
end note

note bottom of "domain"
  No framework annotations.
  Pure game rules and invariants.
  **No Channel, no JPA, no HTTP.**
end note

note bottom of "application"
  Minimal annotations (@Singleton OK).
  Orchestration via port interfaces.
  **No Channel, no JPA, no HTTP.**
end note

note bottom of "infrastructure"
  Framework-heavy (Micronaut, Netty, JPA).
  Implements ports from application layer.
end note

@enduml