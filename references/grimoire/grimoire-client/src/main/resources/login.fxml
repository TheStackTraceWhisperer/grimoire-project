<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.grimoire.client.ui.LoginController"
      alignment="CENTER" spacing="20" styleClass="root" stylesheets="@styles.css">
    
    <Label text="Grimoire MMO" styleClass="header-label"/>
    
    <VBox spacing="12" alignment="CENTER">
        <Label text="Server Address:" styleClass="info-label"/>
        <TextField fx:id="serverField" promptText="localhost:8888"/>
    </VBox>
    
    <Button fx:id="oauthLoginButton" text="Login with OAuth2" onAction="#handleOAuthLogin" 
            styleClass="primary-button"/>
    
</VBox>
